# Copy to .env and fill in. NEVER commit .env.

# --- Database (local docker-compose, or Neon/Supabase free tier) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/job_finder"

# --- Auth (Google OAuth — also grants Gmail send/read scopes) ---
NEXTAUTH_SECRET=""            # `openssl rand -base64 32`
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- LLM (the only paid dependency) ---
ANTHROPIC_API_KEY=""

# --- Free-tier job sources (optional; sources without keys are skipped) ---
ADZUNA_APP_ID=""              # free: developer.adzuna.com
ADZUNA_APP_KEY=""
JOOBLE_API_KEY=""             # free on request: jooble.org/api/about

# --- n8n integration ---
N8N_WEBHOOK_BASE_URL="http://localhost:5678/webhook"
N8N_CALLBACK_SECRET=""        # shared secret; n8n sends it back as x-webhook-secret
