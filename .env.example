# Copy to .env and fill in. NEVER commit .env.

# --- Database (local docker-compose, or Neon/Supabase free tier) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/job_finder"

# --- Auth (Google OAuth — also grants Gmail send/read scopes) ---
# AUTH_SECRET is also used to derive the AES-256 key that encrypts Gmail
# tokens at rest — losing/rotating this value invalidates all stored Gmail
# tokens (users simply re-consent on next sign-in, so it's safe to rotate).
AUTH_SECRET=""                # `npx auth secret` or `openssl rand -base64 32`
GOOGLE_CLIENT_ID=""           # console.cloud.google.com → OAuth client (Web)
GOOGLE_CLIENT_SECRET=""

# --- LLM (Gemini free tier — no card required) ---
GEMINI_API_KEY=""             # free: aistudio.google.com/apikey
GEMINI_MODEL="gemini-2.5-flash"

# --- Free-tier job sources (optional; sources without keys are skipped) ---
ADZUNA_APP_ID=""              # free: developer.adzuna.com
ADZUNA_APP_KEY=""
JOOBLE_API_KEY=""             # free on request: jooble.org/api/about

# --- LaTeX compilation ---
# LATEX_COMPILER: "local" | "remote" — omit to auto-detect (Tectonic binary
# present -> local, else falls back to the free remote compile API).
LATEX_COMPILER=""
LATEX_REMOTE_URL="https://latex.ytotech.com/builds/sync"

# --- Notifications (optional) ---
TELEGRAM_BOT_TOKEN=""          # message @BotFather -> /newbot; users add their chat id in /profile

# --- n8n integration ---
N8N_WEBHOOK_BASE_URL="http://localhost:5678/webhook"
N8N_CALLBACK_SECRET=""        # shared secret; n8n sends it back as x-webhook-secret
