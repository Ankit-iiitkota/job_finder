{
  "name": "WF6 - Reply Detector",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [{ "field": "minutes", "minutesInterval": 15 }] } },
      "name": "Every 15 minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.APP_BASE_URL }}/api/replies/check",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "x-webhook-secret", "value": "={{ $env.N8N_CALLBACK_SECRET }}" }]
        },
        "options": { "timeout": 120000 }
      },
      "name": "POST /api/replies/check",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [260, 0]
    }
  ],
  "connections": {
    "Every 15 minutes": { "main": [[{ "node": "POST /api/replies/check", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "notes": "Polls Gmail threads for sent-but-unanswered emails. On reply: repliedAt stamped, pending follow-up rows deleted, status -> REPLIED."
}
